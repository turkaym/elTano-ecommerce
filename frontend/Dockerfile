FROM node:24-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ARG VITE_API_URL=
ARG VITE_CHECKOUT_MVP_ENABLED=true
ARG VITE_CHECKOUT_PAYMENT_ENABLED=false
ARG VITE_STOREFRONT_VARIANT_FLOW_ENABLED=true
ARG VITE_ADMIN_ENABLED=true
ARG VITE_ADMIN_BASIC_USER=
ARG VITE_ADMIN_BASIC_PASS=

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_CHECKOUT_MVP_ENABLED=$VITE_CHECKOUT_MVP_ENABLED
ENV VITE_CHECKOUT_PAYMENT_ENABLED=$VITE_CHECKOUT_PAYMENT_ENABLED
ENV VITE_STOREFRONT_VARIANT_FLOW_ENABLED=$VITE_STOREFRONT_VARIANT_FLOW_ENABLED
ENV VITE_ADMIN_ENABLED=$VITE_ADMIN_ENABLED
ENV VITE_ADMIN_BASIC_USER=$VITE_ADMIN_BASIC_USER
ENV VITE_ADMIN_BASIC_PASS=$VITE_ADMIN_BASIC_PASS

RUN npm run build

FROM nginx:1.27-alpine AS runtime

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
