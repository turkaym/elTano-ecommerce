# Copy this file to the repository root as .env on the VPS. Do not commit real secrets.

# PostgreSQL container
POSTGRES_DB=eltano_db
POSTGRES_USER=eltano
POSTGRES_PASSWORD=change-me-postgres-password

# Spring datasource
DB_URL=jdbc:postgresql://postgres:5432/eltano_db
DB_USER=eltano
DB_PASSWORD=change-me-postgres-password

# Backend security
JWT_SECRET=change-me-long-random-secret
ADMIN_ENABLED=true
ADMIN_BASIC_USER=change-me-admin-user
ADMIN_BASIC_PASS=change-me-admin-password
STOREFRONT_BASIC_USER=change-me-storefront-user
STOREFRONT_BASIC_PASS=change-me-storefront-password
EXPIRED_ADMIN_BASIC_USER=change-me-expired-admin-user
EXPIRED_ADMIN_BASIC_PASS=change-me-expired-admin-password

# Backend CORS
CORS_ADMIN_ALLOWED_ORIGINS=https://frutoseltano.com.ar,https://www.frutoseltano.com.ar
CORS_STOREFRONT_ALLOWED_ORIGINS=https://frutoseltano.com.ar,https://www.frutoseltano.com.ar

# Uploads
PRODUCT_IMAGE_UPLOAD_DIR=/app/uploads/product-images
PRODUCT_IMAGE_PUBLIC_PATH=/uploads/product-images
PRODUCT_IMAGE_MAX_SIZE_BYTES=5242880

# Mercado Pago
MP_ENABLED=false
MP_API_BASE_URL=https://api.mercadopago.com
MP_ACCESS_TOKEN=change-me-mercadopago-access-token
MP_WEBHOOK_SECRET=replace-with-random-webhook-secret
MP_WEBHOOK_SIGNATURE_REQUIRED=true
MP_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
MP_NOTIFICATION_URL=https://frutoseltano.com.ar/api/payments/mercadopago/webhook
MP_CHECKOUT_SUCCESS_URL=https://frutoseltano.com.ar/checkout/return?result=success
MP_CHECKOUT_FAILURE_URL=https://frutoseltano.com.ar/checkout/return?result=failure
MP_CHECKOUT_PENDING_URL=https://frutoseltano.com.ar/checkout/return?result=pending

# Frontend build args. Empty VITE_API_URL keeps API calls same-origin through the VPS Nginx proxy.
VITE_API_URL=
VITE_CHECKOUT_MVP_ENABLED=true
VITE_CHECKOUT_PAYMENT_ENABLED=false
VITE_STOREFRONT_VARIANT_FLOW_ENABLED=true
VITE_ADMIN_ENABLED=true

# Production risk: these credentials are bundled into browser assets if set.
# Leave empty unless the existing admin UI deployment explicitly requires them.
VITE_ADMIN_BASIC_USER=
VITE_ADMIN_BASIC_PASS=
